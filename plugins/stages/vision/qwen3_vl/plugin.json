{
  "name": "qwen3_vl",
  "display_name": "Qwen3-VL (Vision Translation)",
  "version": "pre-realese-1.0.0",
  "author": "OptikR Team",
  "description": "Single-model OCR + Translation using Qwen3-VL vision-language model. Processes images directly without a separate OCR engine.",
  "type": "vision",
  "engine_type": "qwen3_vl",
  "worker_script": "worker.py",
  "enabled_by_default": false,
  "essential": false,
  "settings": {
    "model_name": {
      "type": "string",
      "default": "Qwen/Qwen3-VL-4B-Instruct",
      "description": "HuggingFace model name for Qwen3-VL variant (use -Instruct or -Thinking suffix)",
      "options": ["Qwen/Qwen3-VL-2B-Instruct", "Qwen/Qwen3-VL-4B-Instruct", "Qwen/Qwen3-VL-8B-Instruct"]
    },
    "max_tokens": {
      "type": "int",
      "default": 512,
      "min": 64,
      "max": 4096,
      "description": "Maximum output token length"
    },
    "temperature": {
      "type": "float",
      "default": 0.3,
      "min": 0.0,
      "max": 2.0,
      "description": "Sampling temperature (lower = more deterministic)"
    },
    "quantization": {
      "type": "string",
      "default": "none",
      "description": "Quantization mode: none, 4bit, or 8bit (requires bitsandbytes)",
      "options": ["none", "4bit", "8bit"]
    },
    "prompt_template": {
      "type": "string",
      "default": "",
      "description": "Prompt template for vision translation. Use {source_lang} and {target_lang} placeholders. Leave empty to use default (or dialogue-only when exclude_sfx is true)."
    },
    "exclude_sfx": {
      "type": "boolean",
      "default": false,
      "description": "Exclude sound effects (SFX); extract and translate only dialogue and narration. Use for manga to get dialogue-only output and higher accuracy when measuring without SFX."
    }
  },
  "dependencies": [
    "transformers",
    "torch",
    "accelerate",
    "qwen_vl_utils"
  ],
  "runtime_requirements": {
    "gpu": {
      "vram_mb": 8000,
      "cuda_required": true
    }
  },
  "supported_languages": [
    "en", "de", "es", "fr", "it", "pt", "ja", "zh", "ko", "ru",
    "ar", "nl", "pl", "tr", "hi", "th", "vi", "id", "uk", "cs"
  ]
}
