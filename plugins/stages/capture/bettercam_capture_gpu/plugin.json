{
  "name": "bettercam_capture_gpu",
  "display_name": "BetterCam Screen Capture (AMD/NVIDIA GPU)",
  "version": "pre-realese-1.0.0",
  "author": "OptikR Team",
  "description": "High-performance screen capture using BetterCam (Desktop Duplication API) - Works with AMD and NVIDIA GPUs",
  "type": "capture",
  "worker_script": "worker.py",
  "enabled_by_default": true,
  "settings": {
    "target_fps": {
      "type": "int",
      "default": 60,
      "description": "Target frames per second for capture",
      "min": 1,
      "max": 240
    },
    "color_mode": {
      "type": "string",
      "default": "BGR",
      "description": "Color mode for captured frames",
      "options": ["BGR", "RGB", "BGRA", "RGBA", "GRAY"]
    },
    "max_buffer_len": {
      "type": "int",
      "default": 64,
      "description": "Maximum frame buffer length",
      "min": 1,
      "max": 512
    }
  },
  "dependencies": [
    "bettercam",
    "numpy",
    "opencv-python"
  ],
  "runtime_requirements": {
    "gpu": {
      "required": true,
      "recommended": true,
      "libraries": ["bettercam"],
      "gpu_features": ["DirectX 11+", "AMD/NVIDIA GPU"]
    },
    "cpu": {
      "supported": false,
      "fallback_plugin": "screenshot_capture_cpu",
      "reason": "BetterCam requires DirectX GPU acceleration"
    }
  },
  "exe_compatibility": {
    "cpu_build": false,
    "gpu_build": true,
    "auto_disable_on_cpu": true
  }
}
