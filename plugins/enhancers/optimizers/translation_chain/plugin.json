{
  "name": "translation_chain",
  "display_name": "Translation Chain Optimizer",
  "version": "pre-realese-1.0.0",
  "type": "optimizer",
  "target_stage": "translation",
  "stage": "pre",
  "description": "Chain translations through intermediate languages for better quality. Fully compatible with learning dictionary.",
  "author": "OptikR Team",
  "enabled": false,
  "pipelines": [
    "visual",
    "audio"
  ],
  "settings": {
    "enable_chaining": {
      "type": "bool",
      "default": false,
      "description": "Enable translation chaining"
    },
    "intermediate_language": {
      "type": "string",
      "default": "en",
      "options": [
        "en",
        "zh",
        "es",
        "fr",
        "de"
      ],
      "description": "Default intermediate language"
    },
    "chain_pairs": {
      "type": "object",
      "default": {
        "ja->de": "ja->en->de",
        "ko->de": "ko->en->de",
        "zh->ja": "zh->en->ja",
        "ar->de": "ar->en->de",
        "th->de": "th->en->de"
      },
      "description": "Language pairs that use chaining (format: 'source->target': 'source->intermediate->target')"
    },
    "save_all_mappings": {
      "type": "bool",
      "default": true,
      "description": "Save intermediate steps and final mapping to dictionary"
    },
    "quality_threshold": {
      "type": "float",
      "default": 0.7,
      "min": 0.0,
      "max": 1.0,
      "description": "Minimum quality score to use direct translation instead of chain"
    },
    "cache_intermediate": {
      "type": "bool",
      "default": true,
      "description": "Cache intermediate translations for reuse"
    }
  },
  "performance": {
    "benefit": "Better translation quality for rare language pairs (25-35% improvement)",
    "overhead": "2x translation time for 2-step chain, 3x for 3-step chain",
    "memory": "Minimal (caches intermediate results)"
  }
}